# Handle line endings automatically for files detected as text
* text=auto

# Explicitly declare text files to use LF line endings
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Explicitly declare binary files to prevent corruption during git operations
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.so binary
